# Python cache files

__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments

venv/
.env/
.venv/
fakenews/

# Jupyter Notebook cache

.ipynb_checkpoints/

# Raw and processed datasets
# Dataset files are large and should not be pushed to GitHub

data/raw/*
data/processed/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Saved models
# Trained models should be generated locally

models/*
*.joblib
*.pkl

# Keep models folder structure
!models/.gitkeep

# Generated metric/report files
# These can be regenerated by running the scripts

reports/*.json
reports/*.txt

# Keep generated figure images for README

!reports/figures/
!reports/figures/*.png
!reports/figures/.gitkeep

# IDE files

.vscode/
.idea/

# System files

.DS_Store
Thumbs.db